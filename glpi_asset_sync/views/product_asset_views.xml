<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         product.product – add GLPI tab to product form
         ============================================================ -->
    <record id="product_product_form_view_glpi" model="ir.ui.view">
        <field name="name">product.product.form.glpi</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="GLPI" name="glpi_tab">
                    <group string="GLPI Identity">
                        <field name="x_glpi_id" readonly="1"/>
                        <field name="x_glpi_itemtype" readonly="1"/>
                        <field name="x_glpi_uuid" readonly="1"/>
                        <field name="x_glpi_asset_tag"/>
                        <field name="x_glpi_last_sync" readonly="1"/>
                    </group>
                    <group string="Raw Payload" invisible="not x_glpi_raw_json">
                        <field name="x_glpi_raw_json" readonly="1" nolabel="1" widget="text"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- ============================================================
         glpi.sync.log – list view
         ============================================================ -->
    <record id="view_glpi_sync_log_list" model="ir.ui.view">
        <field name="name">glpi.sync.log.list</field>
        <field name="model">glpi.sync.log</field>
        <field name="arch" type="xml">
            <list string="GLPI Sync Logs" default_order="sync_start desc"
                  decoration-danger="state == 'error'"
                  decoration-success="state == 'done'">
                <field name="sync_start"/>
                <field name="sync_end"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'done'"
                    decoration-warning="state == 'running'"
                    decoration-danger="state == 'error'"/>
                <field name="fetched"/>
                <field name="created"/>
                <field name="updated"/>
                <field name="skipped"/>
                <field name="error_count"/>
                <field name="duration_seconds" string="Duration (s)"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         glpi.sync.log – form view
         ============================================================ -->
    <record id="view_glpi_sync_log_form" model="ir.ui.view">
        <field name="name">glpi.sync.log.form</field>
        <field name="model">glpi.sync.log</field>
        <field name="arch" type="xml">
            <form string="GLPI Sync Log">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="running,done,error"/>
                </header>
                <sheet>
                    <group string="Run Summary">
                        <field name="sync_start"/>
                        <field name="sync_end"/>
                        <field name="duration_seconds" string="Duration (s)"/>
                    </group>
                    <group string="Record Counts">
                        <field name="fetched"/>
                        <field name="created"/>
                        <field name="updated"/>
                        <field name="skipped"/>
                        <field name="error_count"/>
                    </group>
                    <group string="Errors" invisible="not error_message">
                        <field name="error_message" nolabel="1" widget="text" readonly="1"/>
                    </group>
                    <group string="Per-record Exceptions" invisible="not exceptions">
                        <field name="exceptions" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Action window for glpi.sync.log
         ============================================================ -->
    <record id="action_glpi_sync_log" model="ir.actions.act_window">
        <field name="name">GLPI Sync Logs</field>
        <field name="res_model">glpi.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No sync runs yet.</p>
            <p>Configure GLPI connection in Settings, then trigger a sync
               manually or activate the scheduled action.</p>
        </field>
    </record>

    <!-- ============================================================
         Standalone top-level menu — no dependency on stock/sale/purchase.
         Visible only to administrators (base.group_system).
         ============================================================ -->
    <menuitem
        id="menu_glpi_root"
        name="GLPI Asset Sync"
        sequence="90"
        groups="base.group_system"/>

    <menuitem
        id="menu_glpi_sync_logs"
        name="Sync Logs"
        parent="menu_glpi_root"
        action="action_glpi_sync_log"
        sequence="10"
        groups="base.group_system"/>

</odoo>
