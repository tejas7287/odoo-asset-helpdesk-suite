<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_simple_label2x7">
            <t t-set="barcode_size" t-value="'width:36mm;height:15mm'"/>
            <t t-set="table_style" t-value="'width:97mm;height:37.1mm;' + table_style"/>
            <td t-att-style="make_invisible and 'visibility:hidden;'" >
                <div class="o_label_full o_label_property_sticker o_label_2x7" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode, asset code, and price in top-right -->
                    <div class="o_label_white_section">
                        <t t-if="price_included">
                            <div class="o_label_price_container o_label_price_top_right">
                                <strong class="o_label_price_value" t-out="asset.amount"
                                        t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id, 'label_price': True}"/>
                            </div>
                        </t>
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                    </div>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x7">
            <t t-set="barcode_size" t-value="'width:28mm;height:10mm'"/>
            <t t-set="table_style" t-value="'width:47mm;height:37.1mm;' + table_style"/>
            <td t-att-style="make_invisible and 'visibility:hidden;'" >
                <div class="o_label_full o_label_property_sticker o_label_4x7" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode, asset code, and price -->
                    <div class="o_label_white_section">
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" style="padding:0" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                        <t t-if="price_included">
                            <div class="o_label_price_container">
                                <strong class="o_label_price_value" t-out="asset.amount"
                                        t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id, 'label_price': True}"/>
                            </div>
                        </t>
                    </div>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x12">
            <t t-set="barcode_size" t-value="'width:26mm;height:5mm'"/>
            <t t-set="table_style" t-value="'width:43mm;height:19mm;' + table_style"/>
            <td t-att-style="make_invisible and 'visibility:hidden;'" >
                <div class="o_label_full o_label_property_sticker o_label_4x12" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode, asset code, and price -->
                    <div class="o_label_white_section">
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" style="padding:0" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                        <t t-if="price_included">
                            <div class="o_label_price_container">
                                <strong class="o_label_price_value" t-out="asset.amount"
                                        t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id, 'label_price': True}"/>
                            </div>
                        </t>
                    </div>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x12_no_price">
            <t t-set="barcode_size" t-value="'width:26mm;height:5mm'"/>
            <t t-set="table_style" t-value="'width:43mm;height:19mm;' + table_style"/>
            <td t-att-style="make_invisible and 'visibility:hidden;'" >
                <div class="o_label_full o_label_property_sticker o_label_4x12" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode and asset code (no price) -->
                    <div class="o_label_white_section">
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" style="padding:0" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                    </div>
                </div>
            </td>
        </template>

        <template id="report_simple_label_custom">
            <t t-set="barcode_size" t-value="'width:32mm;height:7mm'"/>
            <t t-set="table_style" t-value="'width:55mm;height:26mm;' + table_style"/>
            <td t-att-style="make_invisible and 'visibility:hidden;'">
                <div class="o_label_full o_label_property_sticker o_label_custom" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode and asset code (no price for custom) -->
                    <div class="o_label_white_section">
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" style="padding:0" t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                    </div>
                </div>
            </td>
        </template>

        <template id="report_simple_label_dymo">
            <div class="o_label_sheet o_label_dymo" t-att-style="padding_page">
                <div class="o_label_full o_label_property_sticker o_label_dymo_format" t-att-style="table_style">
                    <!-- Red band at top with PROPERTY OF and Company Name -->
                    <div class="o_label_red_band" t-att-style="'background-color: ' + (red_band_color or '#dc3545') + ';'">
                        <div class="o_label_property_text">PROPERTY OF</div>
                        <div class="o_label_company_name" t-out="env.company.name"/>
                    </div>
                    <!-- White bottom section with barcode, asset code, and price -->
                    <div class="o_label_white_section">
                        <div class="text-center o_label_barcode_container">
                            <div t-out="barcode" style="padding:0" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': barcode_size}"/>
                            <div class="o_label_asset_code" t-out="barcode"/>
                        </div>
                        <div class="o_label_price_container">
                            <strong class="o_label_price_value" t-out="asset.amount"
                                    t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id, 'label_price': True}"/>
                        </div>
                    </div>
                </div>
            </div>
        </template>

        <template id="report_assetlabel">
            <t t-call="web.html_container">
                <t t-if="columns and rows">
                    <t t-if="columns == 2 and rows == 7">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'2x7'"/>
                    </t>
                    <t t-if="columns == 4 and rows == 7">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'4x7'"/>
                    </t>
                    <t t-if="columns == 4 and rows == 12">
                        <t t-set="padding_page" t-value="'padding: 20mm 8mm'"/>
                        <t t-set="report_to_call" t-value="'4x12'"/>
                    </t>
                    <t t-if="columns != 2 and columns != 4">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'custom'"/>
                    </t>
                    <t t-if="columns == 2 and rows != 7">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'custom'"/>
                    </t>
                    <t t-if="columns == 4 and rows != 7 and rows != 12">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'custom'"/>
                    </t>
                    <t t-foreach="range(page_numbers)" t-as="page">
                        <div class="o_label_sheet" t-att-style="padding_page">
                            <table class="my-0 table table-sm table-borderless" style="table-layout: fixed; width: 100%;">
                                <t t-foreach="range(rows)" t-as="row">
                                    <tr>
                                        <t t-foreach="range(columns)" t-as="column">
                                            <t t-if="not current_quantity and quantity and not (current_data and current_data[1])">
                                                <t t-set="current_data" t-value="quantity.popitem()"/>
                                                <t t-set="asset" t-value="current_data[0]"/>
                                                <t t-set="barcode_and_qty" t-value="current_data[1].pop()"/>
                                                <t t-set="barcode" t-value="barcode_and_qty[0]"/>
                                                <t t-set="current_quantity" t-value="barcode_and_qty[1]"/>
                                            </t>
                                            <t t-if="current_quantity">
                                                <t t-set="make_invisible" t-value="False"/>
                                                <t t-set="current_quantity" t-value="current_quantity - 1"/>
                                            </t>
                                            <t t-elif="current_data and current_data[1]">
                                                <t t-set="barcode_and_qty" t-value="current_data[1].pop()"/>
                                                <t t-set="barcode" t-value="barcode_and_qty[0]"/>
                                                <t t-set="current_quantity" t-value="barcode_and_qty[1] - 1"/>
                                            </t>
                                            <t t-else="">
                                                <t t-set="make_invisible" t-value="True"/>
                                            </t>
                                            <t t-set="table_style" t-value="'border: 1px solid black;'"/>
                                            <t t-if="report_to_call == '2x7'">
                                                <t t-call="asset_management.report_simple_label2x7"/>
                                            </t>
                                            <t t-elif="report_to_call == '4x7'">
                                                <t t-call="asset_management.report_simple_label4x7"/>
                                            </t>
                                            <t t-elif="report_to_call == '4x12'">
                                                <t t-if="price_included == True or price_included == 'True'">
                                                    <t t-call="asset_management.report_simple_label4x12"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-call="asset_management.report_simple_label4x12_no_price"/>
                                                </t>
                                            </t>
                                            <t t-elif="report_to_call == 'custom'">
                                                <t t-call="asset_management.report_simple_label_custom"/>
                                            </t>
                                        </t>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <template id="report_assetlabel_dymo">
            <t t-call="web.html_container">
                <t t-set="barcode_size" t-value="'width:45.5mm;height:7.5mm'"/>
                <t t-set="table_style" t-value="'width:100%;height:32mm;'"/>
                <t t-set="padding_page" t-value="'padding: 2mm'"/>
                <t t-foreach="quantity.items()" t-as="barcode_and_qty_by_asset">
                    <t t-set="asset" t-value="barcode_and_qty_by_asset[0]"/>
                    <t t-foreach="barcode_and_qty_by_asset[1]" t-as="barcode_and_qty">
                        <t t-set="barcode" t-value="barcode_and_qty[0]"/>
                        <t t-foreach="range(barcode_and_qty[1])" t-as="qty">
                            <t t-call="asset_management.report_simple_label_dymo"/>
                        </t>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>

