            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Asset Label Layout Rules (Wizard - TransientModel) -->
        <record model="ir.rule" id="asset_label_layout_user_rule">
            <field name="name">Asset Label Layout Visibility for Users</field>
            <field name="model_id" ref="model_asset_label_layout"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assets_user_group'))]"/>
            <field name="perm_read" eval="True"/>
