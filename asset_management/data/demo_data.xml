<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Demo Asset Types -->
        <record id="demo_asset_type_equipment" model="asset.type">
            <field name="name">Office Equipment</field>
            <field name="color">1</field>
            <field name="depreciation_frequency">yearly</field>
            <field name="depreciation_method">percentage</field>
            <field name="depreciation_rate">20.0</field>
            <field name="depreciation_start_delay">1</field>
            <field name="depreciation_basis">real_value</field>
            <field name="maximum_depreciation_entries">5</field>
        </record>

        <record id="demo_asset_type_vehicles" model="asset.type">
            <field name="name">Vehicles</field>
            <field name="color">2</field>
            <field name="depreciation_frequency">yearly</field>
            <field name="depreciation_method">percentage</field>
            <field name="depreciation_rate">25.0</field>
            <field name="depreciation_start_delay">1</field>
            <field name="depreciation_basis">real_value</field>
            <field name="maximum_depreciation_entries">4</field>
        </record>

        <record id="demo_asset_type_furniture" model="asset.type">
            <field name="name">Office Furniture</field>
            <field name="color">3</field>
            <field name="depreciation_frequency">yearly</field>
            <field name="depreciation_method">percentage</field>
            <field name="depreciation_rate">15.0</field>
            <field name="depreciation_start_delay">1</field>
            <field name="depreciation_basis">real_value</field>
            <field name="maximum_depreciation_entries">7</field>
        </record>

        <record id="demo_asset_type_computers" model="asset.type">
            <field name="name">Computers &amp; IT</field>
            <field name="color">4</field>
            <field name="depreciation_frequency">yearly</field>
            <field name="depreciation_method">percentage</field>
            <field name="depreciation_rate">33.33</field>
            <field name="depreciation_start_delay">1</field>
            <field name="depreciation_basis">real_value</field>
            <field name="maximum_depreciation_entries">3</field>
        </record>

        <record id="demo_asset_type_buildings" model="asset.type">
            <field name="name">Buildings</field>
            <field name="color">5</field>
            <field name="depreciation_frequency">yearly</field>
            <field name="depreciation_method">percentage</field>
            <field name="depreciation_rate">5.0</field>
            <field name="depreciation_start_delay">1</field>
            <field name="depreciation_basis">real_value</field>
            <field name="maximum_depreciation_entries">20</field>
        </record>

        <!-- Demo Asset Tags -->
        <record id="demo_asset_tag_high_value" model="asset.tag">
            <field name="name">High Value</field>
            <field name="color">1</field>
        </record>

        <record id="demo_asset_tag_critical" model="asset.tag">
            <field name="name">Critical</field>
            <field name="color">2</field>
        </record>

        <record id="demo_asset_tag_office" model="asset.tag">
            <field name="name">Office</field>
            <field name="color">3</field>
        </record>

        <record id="demo_asset_tag_warehouse" model="asset.tag">
            <field name="name">Warehouse</field>
            <field name="color">4</field>
        </record>

        <record id="demo_asset_tag_leased" model="asset.tag">
            <field name="name">Leased</field>
            <field name="color">5</field>
        </record>

        <!-- Demo Asset Vendors -->
        <record id="demo_vendor_tech_solutions" model="asset.vendor">
            <field name="name">Tech Solutions Inc.</field>
            <field name="address">123 Tech Street, Silicon Valley, CA 94025</field>
            <field name="location">California, USA</field>
            <field name="seller">John Smith - Sales Manager</field>
            <field name="contact_phone">+1-555-0123</field>
            <field name="contact_email">sales@techsolutions.com</field>
            <field name="additional_services">true</field>
            <field name="repair_service">true</field>
            <field name="maintenance_service">true</field>
        </record>

        <record id="demo_vendor_office_supplies" model="asset.vendor">
            <field name="name">Office Supplies Plus</field>
            <field name="address">456 Business Ave, New York, NY 10001</field>
            <field name="location">New York, USA</field>
            <field name="seller">Sarah Johnson - Account Manager</field>
            <field name="contact_phone">+1-555-0456</field>
            <field name="contact_email">orders@officesupplies.com</field>
            <field name="additional_services">true</field>
            <field name="repair_service">false</field>
            <field name="maintenance_service">false</field>
        </record>

        <record id="demo_vendor_auto_services" model="asset.vendor">
            <field name="name">Auto Services &amp; Maintenance</field>
            <field name="address">789 Garage Road, Chicago, IL 60601</field>
            <field name="location">Illinois, USA</field>
            <field name="seller">Mike Wilson - Service Manager</field>
            <field name="contact_phone">+1-555-0789</field>
            <field name="contact_email">service@autoservices.com</field>
            <field name="additional_services">true</field>
            <field name="repair_service">true</field>
            <field name="maintenance_service">true</field>
        </record>

        <record id="demo_vendor_furniture_warehouse" model="asset.vendor">
            <field name="name">Furniture Warehouse Co.</field>
            <field name="address">321 Furniture Blvd, Miami, FL 33101</field>
            <field name="location">Florida, USA</field>
            <field name="seller">Lisa Brown - Sales Director</field>
            <field name="contact_phone">+1-555-0321</field>
            <field name="contact_email">sales@furniturewarehouse.com</field>
            <field name="additional_services">false</field>
            <field name="repair_service">false</field>
            <field name="maintenance_service">false</field>
        </record>

        <!-- Demo Assets - Single Assets -->
        <record id="demo_asset_laptop_1" model="asset.management">
            <field name="name">ASSET/00001</field>
            <field name="asset_type_id" ref="demo_asset_type_computers"/>
            <field name="model_type">single</field>
            <field name="initial_stock">1</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2026-12-31</field>
            <field name="vendor_id" ref="demo_vendor_tech_solutions"/>
            <field name="invoice_date">2024-06-01</field>
            <field name="amount">1200.00</field>
            <field name="status">assign</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_high_value'), ref('demo_asset_tag_office')])]"/>
        </record>

        <record id="demo_asset_desk_1" model="asset.management">
            <field name="name">ASSET/00002</field>
            <field name="asset_type_id" ref="demo_asset_type_furniture"/>
            <field name="model_type">single</field>
            <field name="initial_stock">1</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2025-12-31</field>
            <field name="vendor_id" ref="demo_vendor_furniture_warehouse"/>
            <field name="invoice_date">2024-09-01</field>
            <field name="amount">450.00</field>
            <field name="status">in_warehouse</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_office')])]"/>
        </record>

        <record id="demo_asset_vehicle_1" model="asset.management">
            <field name="name">ASSET/00003</field>
            <field name="asset_type_id" ref="demo_asset_type_vehicles"/>
            <field name="model_type">single</field>
            <field name="initial_stock">1</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2027-12-31</field>
            <field name="vendor_id" ref="demo_vendor_auto_services"/>
            <field name="invoice_date">2023-12-01</field>
            <field name="amount">25000.00</field>
            <field name="status">assign</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_high_value'), ref('demo_asset_tag_critical')])]"/>
        </record>

        <!-- Demo Assets - Multiple Assets (Stock Managed) -->
        <record id="demo_asset_chairs" model="asset.management">
            <field name="name">ASSET/00004</field>
            <field name="asset_type_id" ref="demo_asset_type_furniture"/>
            <field name="model_type">multiple</field>
            <field name="initial_stock">50</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2026-12-31</field>
            <field name="vendor_id" ref="demo_vendor_furniture_warehouse"/>
            <field name="invoice_date">2024-10-01</field>
            <field name="amount">150.00</field>
            <field name="status">in_warehouse</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_office')])]"/>
        </record>

        <record id="demo_asset_monitors" model="asset.management">
            <field name="name">ASSET/00005</field>
            <field name="asset_type_id" ref="demo_asset_type_computers"/>
            <field name="model_type">multiple</field>
            <field name="initial_stock">25</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2027-12-31</field>
            <field name="vendor_id" ref="demo_vendor_tech_solutions"/>
            <field name="invoice_date">2024-08-01</field>
            <field name="amount">300.00</field>
            <field name="status">in_warehouse</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_office')])]"/>
        </record>

        <record id="demo_asset_printers" model="asset.management">
            <field name="name">ASSET/00006</field>
            <field name="asset_type_id" ref="demo_asset_type_equipment"/>
            <field name="model_type">multiple</field>
            <field name="initial_stock">10</field>
            <field name="depreciation_apply">true</field>
            <field name="expired_warranty_date">2025-12-31</field>
            <field name="vendor_id" ref="demo_vendor_office_supplies"/>
            <field name="invoice_date">2024-11-01</field>
            <field name="amount">800.00</field>
            <field name="status">in_warehouse</field>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_asset_tag_office')])]"/>
        </record>

        <!-- Demo Asset Transfer Entries -->
        <record id="demo_transfer_1" model="asset.transfer.entry">
            <field name="asset_id" ref="demo_asset_laptop_1"/>
            <field name="transfer_employee_id" ref="hr.employee_admin"/>
            <field name="assign_date">2024-11-01</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="status">assigned</field>
            <field name="transfer_code">TRANSFER/00001</field>
            <field name="stock_qty">1</field>
        </record>

        <record id="demo_transfer_2" model="asset.transfer.entry">
            <field name="asset_id" ref="demo_asset_vehicle_1"/>
            <field name="transfer_employee_id" ref="hr.employee_admin"/>
            <field name="assign_date">2024-10-01</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="status">assigned</field>
            <field name="transfer_code">TRANSFER/00002</field>
            <field name="stock_qty">1</field>
        </record>

        <record id="demo_transfer_3" model="asset.transfer.entry">
            <field name="asset_id" ref="demo_asset_chairs"/>
            <field name="transfer_employee_id" ref="hr.employee_admin"/>
            <field name="assign_date">2024-11-15</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="status">assigned</field>
            <field name="transfer_code">TRANSFER/00003</field>
            <field name="stock_qty">5</field>
        </record>

        <record id="demo_transfer_4" model="asset.transfer.entry">
            <field name="asset_id" ref="demo_asset_monitors"/>
            <field name="transfer_employee_id" ref="hr.employee_admin"/>
            <field name="assign_date">2024-11-10</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="status">assigned</field>
            <field name="transfer_code">TRANSFER/00004</field>
            <field name="stock_qty">3</field>
        </record>

        <!-- Demo Asset Maintenance Entries -->
        <record id="demo_maintenance_1" model="asset.maintenance.entry">
            <field name="asset_id" ref="demo_asset_vehicle_1"/>
            <field name="maintenance_vendor_id" ref="demo_vendor_auto_services"/>
            <field name="assign_date">2024-10-15</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="return_date">2024-10-20</field>
            <field name="maintenance_status">completed</field>
            <field name="maintenance_amount">150.00</field>
            <field name="file_name">maintenance_invoice_001.pdf</field>
        </record>

        <record id="demo_maintenance_2" model="asset.maintenance.entry">
            <field name="asset_id" ref="demo_asset_laptop_1"/>
            <field name="maintenance_vendor_id" ref="demo_vendor_tech_solutions"/>
            <field name="assign_date">2024-11-20</field>
            <field name="assign_by" ref="base.user_admin"/>
            <field name="maintenance_status">in_progress</field>
            <field name="maintenance_amount">200.00</field>
            <field name="file_name">laptop_repair_quote.pdf</field>
        </record>

        <!-- Demo Asset Depreciation Entries -->
        <record id="demo_depreciation_1" model="asset.depreciation.entry">
            <field name="asset_id" ref="demo_asset_laptop_1"/>
            <field name="depreciation_amount">200.00</field>
            <field name="entry_date">2024-11-01</field>
            <field name="notes">Monthly depreciation entry - 20% yearly rate</field>
            <field name="created_by" ref="base.user_admin"/>
        </record>

        <record id="demo_depreciation_2" model="asset.depreciation.entry">
            <field name="asset_id" ref="demo_asset_vehicle_1"/>
            <field name="depreciation_amount">6250.00</field>
            <field name="entry_date">2024-11-01</field>
            <field name="notes">Monthly depreciation entry - 25% yearly rate</field>
            <field name="created_by" ref="base.user_admin"/>
        </record>

        <record id="demo_depreciation_3" model="asset.depreciation.entry">
            <field name="asset_id" ref="demo_asset_desk_1"/>
            <field name="depreciation_amount">56.25</field>
            <field name="entry_date">2024-11-01</field>
            <field name="notes">Monthly depreciation entry - 15% yearly rate</field>
            <field name="created_by" ref="base.user_admin"/>
        </record>

    </data>
</odoo>
