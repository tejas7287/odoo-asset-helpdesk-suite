<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="asset_label_layout_form" model="ir.ui.view">
        <field name="name">asset.label.layout.form</field>
        <field name="model">asset.label.layout</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="asset_ids" invisible="1"/>
                        <field name="custom_quantity"/>
                        <field name="print_format" widget="radio"/>
                    </group>
                    <group>
                        <field name="custom_columns" invisible="print_format != 'custom'"/>
                        <field name="custom_rows" invisible="print_format != 'custom'"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="red_band_color" widget="color" string="Label Header Color"/>
                    </group>
                </group>
                <footer>
                    <button name="process" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_label_layout" model="ir.actions.act_window">
        <field name="name">Choose Labels Layout</field>
        <field name="res_model">asset.label.layout</field>
        <field name="view_ids"
                eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'form', 'view_id': ref('asset_label_layout_form')})]" />
        <field name="target">new</field>
    </record>
</odoo>

