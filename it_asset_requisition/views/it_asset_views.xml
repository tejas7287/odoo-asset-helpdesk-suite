<odoo>

    <record id="view_it_asset_tree" model="ir.ui.view">
        <field name="name">it.asset.requisition.list</field>
        <field name="model">it.asset.requisition</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Reference"/>
                <field name="emp_first_name" string="First Name"/>
                <field name="emp_last_name" string="Last Name"/>
                <field name="emp_department" string="Department"/>
                <field name="request_date" string="Date"/>
                <field name="state" widget="badge"/>
                <field name="purchase_id" string="Purchase Order"/>
            </list>
        </field>
    </record>

    <record id="view_it_asset_form" model="ir.ui.view">
        <field name="name">it.asset.requisition.form</field>
        <field name="model">it.asset.requisition</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Create RFQ: only for Purchase Managers, hidden after approval submitted -->
                    <button name="create_rfq"
                            type="object"
                            string="Create RFQ"
                            class="btn-primary"
                            groups="purchase.group_purchase_manager"
                            invisible="state != 'draft'"/>
                    <!-- Status bar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,ordered,dispatched"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">IT Asset Requisition</span>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <group string="Employee Details">
                            <field name="emp_first_name"/>
                            <field name="emp_last_name"/>
                            <field name="emp_designation"/>
                            <field name="emp_department"/>
                            <field name="emp_office_site"/>
                            <field name="emp_code"/>
                            <field name="emp_location"/>
                            <field name="request_date"/>
                        </group>
                        <group string="Manager Details">
                            <field name="manager_first_name"/>
                            <field name="manager_last_name"/>
                            <field name="manager_location"/>
                            <field name="manager_date"/>
                            <field name="email_approval"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Requested Assets" name="assets">
                            <group>
                                <group string="Computer Hardware">
                                    <field name="hardware_product_id"/>
                                </group>
                                <group string="Sim Card">
                                    <field name="sim_product_id"/>
                                </group>
                                <group string="Printer">
                                    <field name="printer_product_id"/>
                                </group>
                            </group>
                            <group string="Others">
                                <group>
                                    <field name="software_checkbox"/>
                                    <field name="software_specify" invisible="not software_checkbox"/>
                                    <field name="pda_checkbox"/>
                                    <field name="pda_count" invisible="not pda_checkbox"/>
                                </group>
                                <group>
                                    <field name="others_text"/>
                                </group>
                            </group>
                        </page>
                        <page string="Justification" name="justification">
                            <group>
                                <field name="justification_type"/>
                                <field name="justification_text" placeholder="Enter the reason for replacement above"/>
                            </group>
                        </page>
                        <page string="IS&amp;T Section" name="ist">
                            <group>
                                <group>
                                    <field name="reqn_rcpt_date"/>
                                    <field name="is_ordered"/>
                                    <field name="is_dispatched"/>
                                    <field name="po_num_text"/>
                                    <field name="purchase_id"/>
                                </group>
                                <group>
                                    <field name="old_device_sn"/>
                                    <field name="device_ageing"/>
                                    <field name="make"/>
                                    <field name="model_name"/>
                                    <field name="ist_others"/>
                                </group>
                            </group>
                            <group string="IS&amp;T Eng Remark">
                                <field name="ist_remark" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Manager Remarks" name="manager_remarks">
                            <group>
                                <field name="manager_remarks" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_asset" model="ir.actions.act_window">
        <field name="name">IT Asset Requisitions</field>
        <field name="res_model">it.asset.requisition</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_it_asset_requisition_orders"
              name="IT Asset Requisition"
              parent="purchase.menu_procurement_management"
              action="action_it_asset"
              groups="purchase.group_purchase_user,purchase.group_purchase_manager"
              sequence="10"/>
</odoo>