<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ============================= -->
        <!-- Helpdesk Ticket Form Update -->
        <!-- ============================= -->
        <record id="view_helpdesk_ticket_form_inherit_asset" model="ir.ui.view">
            <field name="name">helpdesk.ticket.form.asset.inherit</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>

            <field name="arch" type="xml">

                <!-- ✅ ONLY ADD NEW FIELD -->
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="asset_ids"
                           widget="many2many_tags"
                           options="{'no_create': True}"
                           domain="[('current_employee_id.user_id', '=', user_id)]"/>
                </xpath>
            </field>
        </record>

        <!-- ============================= -->
        <!-- Employee Smart Button -->
        <!-- ============================= -->
        <record id="view_employee_form_inherit_ticket" model="ir.ui.view">
            <field name="name">hr.employee.form.ticket.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>

            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">

                    <button name="action_view_tickets"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-ticket">

                        <field name="ticket_count"
                               widget="statinfo"
                               string="Tickets"/>

                    </button>

                </xpath>
            </field>
        </record>

        <record id="view_asset_form_inherit_ticket" model="ir.ui.view">
            <field name="name">asset.management.form.ticket.inherit</field>
            <field name="model">asset.management</field>
            <field name="inherit_id" ref="asset_management.view_asset_form"/>

            <field name="arch" type="xml">

                <!-- ✅ CREATE SMART BUTTON CONTAINER -->
                <xpath expr="//sheet" position="inside">

                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_tickets"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-ticket">

                            <field name="ticket_count"
                                   widget="statinfo"
                                   string="Tickets"/>

                        </button>

                    </div>

                </xpath>

            </field>
        </record>

    </data>
</odoo>